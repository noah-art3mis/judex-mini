# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

.venv
.env
/notes/
/data/
/analysis/
/exports/
.claude/

# Local-only config — proxy pool, any other credentials / secrets.
# Whole dir is ignored; create `config/` locally, put proxies.txt inside.
/config/

# Proxy-pool files at any location. Broad patterns because the name
# varies by provider and it's safer to over-match than to leak creds.
proxies.txt
proxies*.txt
*.proxies

# Operational sweep artifacts — state files, logs, per-shard outputs.
# The whole tree is gitignored; human-written narratives (REPORT,
# SUMMARY, PLAN) get promoted to docs/reports/ instead.
/runs/

# Operational artifacts under state/. The directory itself is tracked
# (daily_report.json, watchlist/ are persisted state we *want* in git),
# but logs, request audit DBs, and canary outputs are not.
/state/logs/
/state/canary-outputs/
/state/requests-archive.duckdb
