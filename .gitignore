# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

.venv
.env
/notes/
/data/
/analysis/
/exports/
.claude/

# Local-only config — proxy pool, any other credentials / secrets.
# Whole dir is ignored; create `config/` locally, put proxies.txt inside.
/config/

# Proxy-pool files at any location. Broad patterns because the name
# varies by provider and it's safer to over-match than to leak creds.
proxies.txt
proxies*.txt
*.proxies

# Ephemeral sweep state — regenerated on every run, pure churn in diffs.
# What stays tracked: report.md, PLAN.md, SUMMARY.md (summaries), and
# *.log.jsonl / *.errors.jsonl (append-only audit logs treated as
# archival). Only the transient-current-position files are ignored.
docs/sweep-results/**/sweep.state.json
docs/sweep-results/**/driver.log
docs/pdf-sweeps/**/pdfs.state.json
docs/pdf-sweeps/**/run.log
docs/pdf-sweeps/**/requests.db
