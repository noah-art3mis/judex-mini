# judex-mini — operator-local secrets and paid-infra endpoints
#
# Copy this file to `.env` (which is gitignored) and fill in the values
# you need. The CLI auto-loads `.env` at startup via python-dotenv;
# every variable listed here is read by a specific provider module
# only when you select it via `--provedor` or call into it directly.
#
# Filling in NOTHING is a valid default — the CLI runs fine for the
# free providers (`pypdf`, local `tesseract`) without any of these.
# A given variable is only required when you `--provedor <X>` for the
# matching provider.
#
# DO NOT commit your filled-in `.env`. It carries credentials that can
# bill real money and tokens scoped to your accounts.


# -- Fly.io self-hosted Tesseract ---------------------------------------------
# Provider: --provedor tesseract_fly
# Read by:  judex/scraping/ocr/tesseract_fly.py
# What:    HTTPS endpoint of YOUR Fly.io Machine running the Tesseract HTTP
#          service (image + service definition live in `fly/` at repo root).
# Deploy:  cd fly && flyctl deploy
# Cost:    ~$0.013 / 1k pages on shared-cpu-2x in São Paulo (gru). You pay
#          Fly directly; nothing flows through the project author.
FLY_TESSERACT_URL=


# -- Datalab Chandra ----------------------------------------------------------
# Provider: --provedor chandra
# Read by:  judex/scraping/ocr/chandra.py
# What:    API key from https://www.datalab.to/. Used for high-quality OCR
#          on scanned/image-only PDFs. Pay-per-call; check current pricing.
DATALAB_API_KEY=


# -- RunPod Chandra (self-hosted Chandra on RunPod serverless) ----------------
# Provider: --provedor chandra_runpod
# Read by:  judex/scraping/ocr/chandra_runpod.py + scripts/runpod_status.py
# What:    Bearer token + endpoint id for YOUR RunPod serverless deployment.
#          Cheaper than Datalab when you have steady throughput; cold-start
#          latency is the tradeoff.
RUNPOD_API_KEY=
RUNPOD_CHANDRA_ENDPOINT_ID=


# -- Mistral OCR --------------------------------------------------------------
# Provider: --provedor mistral
# Read by:  judex/scraping/ocr/mistral.py
# What:    API key from https://console.mistral.ai/.
MISTRAL_API_KEY=


# -- Google Gemini ------------------------------------------------------------
# Provider: --provedor gemini
# Read by:  judex/scraping/ocr/gemini.py
# What:    API key from https://aistudio.google.com/apikey.
GEMINI_API_KEY=


# -- Unstructured.io ----------------------------------------------------------
# Provider: --provedor unstructured
# Read by:  judex/scraping/ocr/unstructured.py
# What:    API key from https://unstructured.io/api-key-free.
UNSTRUCTURED_API_KEY=
